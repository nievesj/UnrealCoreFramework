# =====================================================================
# Unreal Engine 5 C++ Coding Standard — .clang-format
#
# Sources:
#   Epic Games Coding Standard (UE 5.5):
#     https://dev.epicgames.com/documentation/en-us/unreal-engine/epic-cplusplus-coding-standard-for-unreal-engine
#   TensorWorks UE Clang-Format reference:
#     https://github.com/TensorWorks/UE-Clang-Format
# =====================================================================

Language:     Cpp
BasedOnStyle: LLVM
Standard:     Latest        # UE 5.x requires C++20 minimum

# ------------------------------------------
# UE Reflection & Generated-Code Macros
# Treated as opaque statements so clang-format
# never tries to split them across lines.
# ------------------------------------------
StatementMacros:
  - UPROPERTY
  - UFUNCTION
  - UCLASS
  - USTRUCT
  - UENUM
  - UINTERFACE
  - UMETA
  - UPARAM
  - UDELEGATE
  - GENERATED_BODY
  - GENERATED_UCLASS_BODY
  - GENERATED_USTRUCT_BODY
  - GENERATED_UINTERFACE_BODY

# ------------------------------------------
# Access Modifiers
# Epic: public → protected → private order.
# Modifiers are outdented -4 relative to class body.
# ------------------------------------------
AccessModifierOffset:          -4
EmptyLineBeforeAccessModifier: LogicalBlock

# ------------------------------------------
# Alignment
# ------------------------------------------
AlignAfterOpenBracket:        DontAlign   # args use ContinuationIndentWidth, not aligned to '('
AlignConsecutiveDeclarations: false        # no column-aligning of variable declarations
AlignConsecutiveMacros:       false
AlignEscapedNewlines:         Left
AlignOperands:                DontAlign
AlignTrailingComments:        true

# ------------------------------------------
# Single-line Short Forms
# Epic standard: always use braces; no inline one-liners.
# "Bad: int32 GetSize() const { return Size; }"  — Coding Standard
# ------------------------------------------
AllowShortBlocksOnASingleLine:       Empty    # only truly empty blocks: {}
AllowShortCaseLabelsOnASingleLine:   false
AllowShortEnumsOnASingleLine:        false
AllowShortFunctionsOnASingleLine:    None     # Epic explicitly forbids single-line functions
AllowShortIfStatementsOnASingleLine: Never    # Epic: always brace single-statement ifs
AllowShortLambdasOnASingleLine:      All      # short predicate lambdas are idiomatic in UE
AllowShortLoopsOnASingleLine:        false    # Epic: always brace loops

# ------------------------------------------
# Templates
# Epic uses `template <typename T>` on its own line.
# ------------------------------------------
AlwaysBreakTemplateDeclarations: Yes
SpaceAfterTemplateKeyword:       true    # template <typename T>  ← space after 'template'

# ------------------------------------------
# Argument / Parameter Packing
# One arg per line when a call/declaration must break.
# ------------------------------------------
BinPackArguments:  false
BinPackParameters: false

# ------------------------------------------
# Braces — Allman style (Epic's long-standing brace pattern)
# "Epic Games has a long standing usage pattern of putting
#  braces on a new line."  — Coding Standard
# ------------------------------------------
BreakBeforeBraces: Custom
BraceWrapping:
    AfterCaseLabel:        true
    AfterClass:            true
    AfterControlStatement: true
    AfterEnum:             true
    AfterFunction:         true
    AfterNamespace:        true
    AfterObjCDeclaration:  true
    AfterStruct:           true
    AfterUnion:            true
    AfterExternBlock:      true
    BeforeCatch:           true
    BeforeElse:            true
    BeforeLambdaBody:      false   # keep short lambdas compact: []() { ... }
    BeforeWhile:           true
    IndentBraces:          false
    SplitEmptyFunction:    true
    SplitEmptyRecord:      true
    SplitEmptyNamespace:   true

# ------------------------------------------
# Line-Breaking Rules
# ------------------------------------------
BreakBeforeBinaryOperators:  NonAssignment
BreakBeforeTernaryOperators: true

# Constructor initializer style — Epic one-per-line before comma:
#   : MemberA(0)
#   , MemberB(TEXT("x"))
BreakConstructorInitializers:                   BeforeComma
PackConstructorInitializers:                    Never   # clang-format 14+
ConstructorInitializerAllOnOneLineOrOnePerLine: true    # legacy compat (<14)

BreakInheritanceList: AfterColon
BreakStringLiterals:  false

CompactNamespaces: false   # keep nested namespaces on separate lines

# ------------------------------------------
# Column Limit
# Epic has no fixed column limit.
# 0 = unlimited — avoids spurious line-breaks in long UE declarations.
# ------------------------------------------
ColumnLimit: 0

# ------------------------------------------
# C++11 Brace-Init Lists
# false → spaces inside aggregate initialiser braces:
#   { 56, 23, "hello" }  — consistent with UE array/struct examples
# ------------------------------------------
Cpp11BracedListStyle: false

# ------------------------------------------
# Indentation — tabs, 4 characters wide (Epic mandate)
# "Use tabs for whitespace at the beginning of a line, not spaces.
#  Set your tab size to 4 characters."  — Coding Standard
# ------------------------------------------
ContinuationIndentWidth: 4
IndentCaseBlocks:        false   # no extra indent inside case { } blocks
IndentCaseLabels:        true    # indent case labels relative to switch body
IndentPPDirectives:      BeforeHash
IndentWidth:             4
TabWidth:                4
UseTab:                  Always

# ------------------------------------------
# Namespaces
# ------------------------------------------
NamespaceIndentation: All
FixNamespaceComments: true   # appends // namespace Foo after closing brace

# ------------------------------------------
# Pointer & Reference Alignment
# "Pointers and references should only have one space to the right
#  of the pointer or reference."
#   FShaderType* Ptr  /  FShaderType& Ref  — Coding Standard
# ------------------------------------------
DerivePointerAlignment: false
PointerAlignment:       Left
ReferenceAlignment:     Left

# ------------------------------------------
# Includes
# UE requires a specific include order (project header first,
# then engine, then generated last).  NEVER auto-sort.
# ------------------------------------------
SortIncludes: Never

# ------------------------------------------
# Spacing
# ------------------------------------------
SpaceAfterCStyleCast:      false              # (int32)value  not  (int32) value
SpaceBeforeCaseColon:      false
SpaceBeforeParens:         ControlStatements  # space before ( in if/for/while, not in calls
SpacesInAngles:            Never
SpacesInContainerLiterals: false

# ------------------------------------------
# Empty Lines
# ------------------------------------------
KeepEmptyLinesAtTheStartOfBlocks: false
MaxEmptyLinesToKeep:               2

# ------------------------------------------
# Comments
# Do NOT reflow UE JavaDoc / doxygen comment blocks —
# Epic uses a structured format for auto-doc generation.
# ------------------------------------------
ReflowComments: false
